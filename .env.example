# KFIP v0.1 env template.
# Copy to `.env.local` and fill in for local development.
# v0.1 doesn't yet require these — the UI is mocked. v0.2 wires real XRPL.

# Testnet endpoints (defaults are fine).
XRPL_TESTNET_URL=wss://s.altnet.rippletest.net:51233
XRPL_TESTNET_EXPLORER=https://testnet.xrpl.org

# Demo wallet seeds — testnet only, NEVER reuse on mainnet.
# Generate via `bun -e "import('xrpl').then(({Wallet}) => console.log(Wallet.generate().seed))"`
# or fund a fresh one via lib/xrpl.ts `fundFromFaucet()` on first boot.
KFIP_PARENT_SEED=
KFIP_CHILD_SEED=
