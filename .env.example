# KFIP v0.1 env template.
# Copy to `.env.local` and fill in for local development.
# v0.1 doesn't yet require these — the UI is mocked. v0.2 wires real XRPL.

# Testnet endpoints (defaults are fine).
XRPL_TESTNET_URL=wss://s.altnet.rippletest.net:51233
XRPL_TESTNET_EXPLORER=https://testnet.xrpl.org

# Demo wallet seeds — testnet only, NEVER reuse on mainnet.
# Generate via `bun -e "import('xrpl').then(({Wallet}) => console.log(Wallet.generate().seed))"`
# or fund a fresh one via lib/xrpl.ts `fundFromFaucet()` on first boot.
KFIP_PARENT_SEED=
KFIP_CHILD_SEED=
# Set after running `bun run setup:wallets` (v0.2+, three-wallet setup).
KFIP_PARENT_ADDRESS=
KFIP_CHILD_ADDRESS=
KFIP_MERCHANT_ADDRESS=

# --- v0.5: optional Vercel KV (Upstash Redis) for state persistence ---
# When deployed on Vercel: enable the KV integration (Settings → Integrations →
# Marketplace → Upstash Redis or Vercel KV). Vercel auto-injects these vars.
# Locally these are optional — the app falls back to `.kfip-state.json`.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Alternative (raw Upstash):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
